{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Response returned after accepting a training request.",
  "properties": {
    "status": {
      "const": "accepted",
      "title": "Status",
      "type": "string"
    },
    "submission_id": {
      "minLength": 1,
      "title": "Submission Id",
      "type": "string"
    }
  },
  "required": [
    "status",
    "submission_id"
  ],
  "title": "TrainingResponse",
  "type": "object"
}
